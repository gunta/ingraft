{
  "name": "ingraft",
  "version": "0.3.0",
  "description": "Vendor external git repositories into a project for coding agents.",
  "license": "MIT",
  "bin": {
    "ingraft": "./dist/bin/ingraft.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/src/cli.d.ts",
      "default": "./dist/src/cli.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && mkdir -p dist/src/aliases && cp src/aliases/repository-aliases.json dist/src/aliases/repository-aliases.json && chmod +x dist/bin/ingraft.js",
    "check": "bun run lint && bun run format:check && bun run typecheck && bun run test",
    "dev": "bun scripts/vendor.ts",
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "test": "bun test tests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@effect/cli": "^0.75.1",
    "@effect/platform": "^0.96.1",
    "@effect/platform-node": "^0.106.0",
    "@iarna/toml": "2.2.5",
    "@opentui/core": "^0.2.8",
    "@xmldom/xmldom": "0.9.10",
    "effect": "^3.21.2",
    "ink": "^7.0.2",
    "isomorphic-git": "^1.37.6",
    "jscodeshift": "17.3.0",
    "jsonc-parser": "^3.3.1",
    "react": "^19.2.6",
    "ts-morph": "28.0.0",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14"
  },
  "engines": {
    "node": ">=20.11"
  }
}
