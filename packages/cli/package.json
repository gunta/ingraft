{
  "name": "vendor-subtree",
  "version": "0.3.0",
  "description": "Vendor external git repositories into a project for coding agents.",
  "type": "module",
  "bin": {
    "vendor-subtree": "./dist/bin/vendor-subtree.js"
  },
  "exports": {
    ".": {
      "types": "./dist/src/cli.d.ts",
      "default": "./dist/src/cli.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && chmod +x dist/bin/vendor-subtree.js",
    "dev": "bun scripts/vendor.ts",
    "test": "bun test tests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20.11"
  },
  "license": "MIT",
  "dependencies": {
    "@effect/cli": "^0.75.1",
    "@effect/platform": "^0.96.1",
    "@effect/platform-node": "^0.106.0",
    "@iarna/toml": "2.2.5",
    "@xmldom/xmldom": "0.9.10",
    "effect": "^3.21.2",
    "isomorphic-git": "^1.37.6",
    "jscodeshift": "17.3.0",
    "jsonc-parser": "^3.3.1",
    "ts-morph": "28.0.0",
    "yaml": "2.9.0"
  }
}
