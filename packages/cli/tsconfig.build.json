{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "noEmit": false,
    "outDir": "dist",
    "rootDir": ".",
    "sourceMap": true,
    "tsBuildInfoFile": "../../.tsbuildinfo/packages-cli-build.tsbuildinfo",
    "types": ["node"],
    "rewriteRelativeImportExtensions": true
  },
  "include": ["bin/**/*.ts", "src/**/*.ts"],
  "exclude": ["dist", "scripts", "tests"]
}
