{
  "name": "vendor-subtree-tui",
  "version": "0.3.0",
  "description": "OpenTUI dashboard for managing vendor-subtree repositories.",
  "license": "MIT",
  "bin": {
    "vendor-subtree-tui": "./src/index.ts"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "check": "bun run lint && bun run format:check && bun run typecheck && bun run test",
    "dev": "bun src/index.ts",
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "test": "bun test tests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@opentui/core": "^0.2.8"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "bun-types": "^1.3.13",
    "typescript": "^6.0.3"
  }
}
