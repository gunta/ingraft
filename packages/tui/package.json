{
  "name": "@ingraft/tui-workspace",
  "version": "0.3.0",
  "private": true,
  "description": "OpenTUI dashboard for managing ingraft repositories.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "check": "bun run lint && bun run format:check && bun run typecheck",
    "dev": "bun src/index.ts",
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@opentui/core": "^0.2.8"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "bun-types": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
